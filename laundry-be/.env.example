APP_NAME=Laundry Multi-Platform
APP_ENV=development
APP_PORT=3000

# CORS — pisahkan beberapa origin dengan koma
# Development: http://localhost:3001
# Production: https://admin.dicuciin.com
ALLOWED_ORIGINS=http://localhost:3001

# Margin laba bersih dalam persen (default 80 = 80%)
# Digunakan untuk kalkulasi estimasi profit di laporan keuangan
PROFIT_MARGIN_PERCENT=80

# Database
DATABASE_URL=postgresql://laundry:laundry_password@localhost:5432/laundry_db?schema=public

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT
MQTT_URL=mqtt://localhost:1883
